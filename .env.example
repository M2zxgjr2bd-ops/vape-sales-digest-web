# Optional but recommended: protects manual/admin-only endpoints.
CRON_SECRET=replace-with-a-random-16-plus-char-secret

# Optional but recommended: enables higher-quality digest generation.
OPENAI_API_KEY=sk-xxxxxxxxx
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_MS=45000
OPENAI_ITEM_LIMIT=8
OPENAI_EXCERPT_CHARS=900

# Optional overrides.
DIGEST_TIMEZONE=Asia/Shanghai
LEAD_SOURCE_URLS=
MAX_ITEMS_PER_SOURCE=6
MAX_DIGEST_ITEMS=12
MAX_ARTICLE_CHARS=2200
FETCH_TIMEOUT_MS=12000
